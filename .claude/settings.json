{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(npm run:*)",
      "Bash(npm test)",
      "Bash(npm test:*)",
      "Bash(npx vitest:*)",
      "Bash(npx playwright:*)",
      "Bash(npx playwright install:*)",
      "Bash(npx orval:*)",
      "Bash(npx biome:*)",
      "Bash(npx tsc:*)",
      "Bash(npx shadcn:*)",
      "Bash(npx msw:*)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git restore:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(node --version)",
      "Bash(npm --version)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)",
      "Bash(npm publish:*)"
    ],
    "ask": ["Bash(git commit:*)", "Bash(git checkout:*)", "Bash(git rebase:*)", "Bash(git merge:*)"]
  }
}
